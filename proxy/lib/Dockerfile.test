# Dockerfile for running proxy-utils tests
# Use the same base image as production to ensure compatibility
FROM envoyproxy/envoy:v1.31.0

# Install luarocks and busted (test framework)
RUN apt update && apt install -y luarocks
RUN luarocks-5.1 install --local busted

# Set environment for local luarocks
ENV PATH="/root/.luarocks/bin:${PATH}"
ENV LUA_PATH="/root/.luarocks/share/lua/5.1/?.lua;/root/.luarocks/share/lua/5.1/?/init.lua;/usr/local/share/lua/5.1/?.lua;/usr/local/share/lua/5.1/?/init.lua;;"
ENV LUA_CPATH="/root/.luarocks/lib/lua/5.1/?.so;/usr/local/lib/lua/5.1/?.so;;"

# Set working directory
WORKDIR /app

# Copy library files
COPY proxy_utils/ /app/proxy_utils/
COPY spec/ /app/spec/
COPY proxy-utils-1.0-0.rockspec /app/
COPY .busted /app/

# Install the library (dependencies auto-installed from rockspec)
RUN luarocks-5.1 make --local proxy-utils-1.0-0.rockspec

# Override entrypoint to run as root
ENTRYPOINT []
CMD ["busted", "--verbose"]
